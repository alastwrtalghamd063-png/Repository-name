<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>أرامكو للاستثمار - سحب الأرباح</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <style>
        :root {
            --primary: #4d7cfe;
            --primary-gradient: linear-gradient(135deg, #4d7cfe 0%, #2563eb 100%);
            --surface: #f8f9ff;
            --on-surface: #1a1c1e;
        }
        body {
            font-family: 'IBM Plex Sans Arabic', sans-serif;
            background-color: var(--surface);
            color: var(--on-surface);
            margin: 0;
            padding-bottom: 90px;
        }
        .header-bg {
            background: var(--primary-gradient);
            border-radius: 0 0 40px 40px;
        }
        .card {
            background: white;
            border-radius: 24px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
            border: 1px solid rgba(226, 232, 240, 0.5);
        }
        .input-field {
            width: 100%;
            padding: 1rem 3rem 1rem 1rem;
            border-radius: 1rem;
            border: 1px solid #e2e8f0;
            background: #fcfdfe;
            font-size: 0.95rem;
            transition: all 0.2s ease;
        }
        .input-field:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(77, 124, 254, 0.1);
            outline: none;
        }
        .btn-primary {
            width: 100%;
            padding: 1rem;
            border-radius: 1rem;
            background-color: var(--primary);
            color: white;
            font-weight: 700;
            box-shadow: 0 10px 20px rgba(77, 124, 254, 0.2);
            transition: all 0.2s;
        }
        .btn-primary:active {
            transform: scale(0.97);
        }
    </style>
</head>
<body>

    <!-- Header Section -->
    <header class="header-bg text-white pt-12 pb-16 px-6 relative overflow-hidden">
        <div class="flex justify-between items-center mb-8 relative z-10">
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-3xl">payments</span>
                <h1 class="text-2xl font-bold tracking-tight">سحب الأرباح</h1>
            </div>
            <a href="profile.html" class="bg-white/20 p-2 rounded-full backdrop-blur-md">
                <span class="material-symbols-outlined text-xl">arrow_forward</span>
            </a>
        </div>
        <div class="text-center relative z-10">
            <p class="text-white/80 text-sm mb-1">الرصيد القابل للسحب</p>
            <h2 class="text-4xl font-black">$12,450.00</h2>
        </div>
    </header>

    <main class="px-5 -mt-8 relative z-20">
        <div class="card p-6 mb-6">
            <form onsubmit="handleWithdraw(event)">
                <div class="mb-5">
                    <label class="block text-sm font-bold text-slate-700 mb-2 pr-1">عنوان المحفظة (USDT-TRC20)</label>
                    <div class="relative">
                        <input type="text" class="input-field" placeholder="أدخل عنوان المحفظة هنا" required>
                        <span class="material-symbols-outlined absolute top-1/2 right-4 -translate-y-1/2 text-slate-400">account_balance_wallet</span>
                        <button type="button" class="absolute top-1/2 left-4 -translate-y-1/2 text-primary font-bold text-xs">لصق</button>
                    </div>
                </div>

                <div class="mb-5">
                    <label class="block text-sm font-bold text-slate-700 mb-2 pr-1">مبلغ السحب</label>
                    <div class="relative">
                        <input type="number" class="input-field" placeholder="الحد الأدنى 3 USDT" required min="3">
                        <span class="material-symbols-outlined absolute top-1/2 right-4 -translate-y-1/2 text-slate-400">monetization_on</span>
                        <button type="button" class="absolute top-1/2 left-4 -translate-y-1/2 text-primary font-bold text-xs">الكل</button>
                    </div>
                </div>

                <!-- Fee Info -->
                <div class="bg-green-50 border border-green-100 rounded-2xl p-4 mb-6 flex items-center justify-between">
                    <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-green-600">verified_user</span>
                        <span class="text-sm font-bold text-green-700">رسوم السحب</span>
                    </div>
                    <span class="text-lg font-black text-green-600">0% مجاني</span>
                </div>

                <button type="submit" class="btn-primary flex items-center justify-center gap-2">
                    <span>تأكيد السحب الآن</span>
                    <span class="material-symbols-outlined">send</span>
                </button>
            </form>
        </div>

        <!-- Instructions -->
        <div class="bg-blue-50/50 rounded-3xl p-6 border border-blue-100">
            <h4 class="font-bold text-blue-800 mb-3 flex items-center gap-2">
                <span class="material-symbols-outlined text-lg">info</span>
                تعليمات هامة
            </h4>
            <ul class="text-xs text-blue-700 space-y-2 leading-relaxed">
                <li>• تأكد من صحة عنوان المحفظة، المنصة غير مسؤولة عن العناوين الخاطئة.</li>
                <li>• السحب يتم عبر شبكة TRC20 فقط لضمان السرعة وبدون رسوم.</li>
                <li>• تستغرق عملية المعالجة من 5 دقائق إلى 24 ساعة كحد أقصى.</li>
            </ul>
        </div>
    </main>

    <!-- Navigation -->
    <nav class="fixed bottom-0 left-0 w-full bg-white border-t border-gray-100 flex justify-around items-center py-3 px-2 z-50 pb-safe">
        <a href="index.html" class="flex flex-col items-center gap-1 text-gray-400">
            <span class="material-symbols-outlined">home</span>
            <span class="text-[10px]">الرئيسية</span>
        </a>
        <a href="tasks.html" class="flex flex-col items-center gap-1 text-gray-400">
            <span class="material-symbols-outlined">assignment</span>
            <span class="text-[10px]">المهام</span>
        </a>
        <a href="team.html" class="flex flex-col items-center gap-1 text-gray-400">
            <span class="material-symbols-outlined">group</span>
            <span class="text-[10px]">الفريق</span>
        </a>
        <a href="vip.html" class="flex flex-col items-center gap-1 text-gray-400">
            <span class="material-symbols-outlined">military_tech</span>
            <span class="text-[10px]">VIP</span>
        </a>
        <a href="profile.html" class="flex flex-col items-center gap-1 text-primary font-bold">
            <span class="material-symbols-outlined">person</span>
            <span class="text-[10px]">حسابي</span>
        </a>
    </nav>

    <script>
        function handleWithdraw(e) {
            e.preventDefault();
            alert('تم تقديم طلب السحب بنجاح! سيتم تحويل المبلغ لمحفظتك قريباً بدون أي رسوم.');
            window.location.href = 'profile.html';
        }
    </script>
</body>
</html>
